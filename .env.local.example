
# ---- Phase 3 auto-minter (server-only; set these in Vercel, NOT committed) ----
# SUPABASE_SERVICE_ROLE_KEY=...      # Supabase → Settings → API → service_role (secret)
# PTR_CONTRACT_ADDRESS=0x...         # deployed PutraToken address (Polygon Amoy)
# PTR_RPC_URL=https://rpc-amoy.polygon.technology
# MINTER_PRIVATE_KEY=0x...           # key holding MINTER_ROLE (testnet key only)
# MINT_ADMIN_SECRET=long-random-string   # bearer token to trigger POST /api/mint
# CRON_SECRET=long-random-string         # Vercel sets this automatically for cron GET
