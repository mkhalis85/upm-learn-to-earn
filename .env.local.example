# Copy to .env.local and fill in from your Supabase project (Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional: restrict signups to these email domains (comma-separated).
# Leave blank to allow any email.
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAINS=upm.edu.my,student.upm.edu.my
